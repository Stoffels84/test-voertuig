// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: stats
// Document ID: visitors
// Fields:
//   - count: number (required) - The current visitor count
//
// Collection: messages
// Document ID: auto-generated
// Fields:
//   - text: string (required, max 200 chars)
//   - author: string (required, max 50 chars)
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidStat(data) {
      return data.keys().hasOnly(['count']) && 
             data.count is number && 
             data.count >= 0;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'author', 'timestamp']) &&
             data.keys().hasOnly(['text', 'author', 'timestamp']) &&
             data.text is string && data.text.size() <= 200 &&
             data.author is string && data.author.size() <= 50 &&
             data.timestamp is timestamp;
    }

    // Visitor Counter
    match /stats/visitors {
      // Allow public reading of the visitor count
      allow read: if true;
      
      // Allow initial creation if count is 1
      allow create: if isValidStat(request.resource.data) && 
                      request.resource.data.count == 1;
      
      // Allow incrementing the count by exactly 1
      allow update: if isValidStat(request.resource.data) && 
                      request.resource.data.count == resource.data.count + 1;
    }

    // Message Board
    match /messages/{messageId} {
      allow read: if true;
      allow create: if isValidMessage(request.resource.data);
      allow delete: if false;
      allow update: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
